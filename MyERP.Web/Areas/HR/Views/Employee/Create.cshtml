@model MyERP.Web.Areas.HR.Models.Employee

@{
    ViewData["Title"] = "فتح ملف موظف جديد";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark">@ViewData["Title"]</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index">سجل الموظفين</a></li>
                    <li class="breadcrumb-item active">إضافة جديد</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="card card-primary card-outline card-tabs">
                <div class="card-header p-0 pt-1 border-bottom-0">
                    <ul class="nav nav-tabs" id="employee-tabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="personal-info-tab" data-bs-toggle="pill" href="#personal-info" role="tab" aria-controls="personal-info" aria-selected="true">البيانات الشخصية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="contact-info-tab" data-bs-toggle="pill" href="#contact-info" role="tab" aria-controls="contact-info" aria-selected="false">معلومات التواصل</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="employment-info-tab" data-bs-toggle="pill" href="#employment-info" role="tab" aria-controls="employment-info" aria-selected="false">بيانات التوظيف</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="education-info-tab" data-bs-toggle="pill" href="#education-info" role="tab" aria-controls="education-info" aria-selected="false">المؤهلات والتعليم</a>
                        </li>
                    </ul>
                </div>

                <div class="card-body">
                    <div class="tab-content" id="employee-tabs-content">

                        <!-- Personal Information Tab -->
                        <div class="tab-pane fade show active" id="personal-info" role="tabpanel" aria-labelledby="personal-info-tab">
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="Name" class="control-label">الاسم <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="NationalId" class="control-label">الرقم القومي</label>
                                    <input asp-for="NationalId" class="form-control" />
                                    <span asp-validation-for="NationalId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-4">
                                    <label asp-for="DateOfBirth" class="control-label">تاريخ الميلاد</label>
                                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="Gender" class="control-label">النوع</label>
                                    <select asp-for="Gender" class="form-control">
                                        <option value="">-- اختر --</option>
                                        <option value="ذكر">ذكر</option>
                                        <option value="أنثى">أنثى</option>
                                    </select>
                                    <span asp-validation-for="Gender" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="MaritalStatus" class="control-label">الحالة الاجتماعية</label>
                                    <select asp-for="MaritalStatus" class="form-control">
                                        <option value="">-- اختر --</option>
                                        <option value="أعزب">أعزب</option>
                                        <option value="متزوج">متزوج</option>
                                        <option value="مطلق">مطلق</option>
                                        <option value="أرمل">أرمل</option>
                                    </select>
                                    <span asp-validation-for="MaritalStatus" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-4">
                                    <label asp-for="CityCenterId" class="control-label">المدينة/المركز</label>
                                    <select asp-for="CityCenterId" class="form-control" asp-items="ViewBag.CityCenterId"></select>
                                    <span asp-validation-for="CityCenterId" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="VillageId" class="control-label">القرية</label>
                                    <select asp-for="VillageId" class="form-control" asp-items="ViewBag.VillageId"></select>
                                    <span asp-validation-for="VillageId" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="Address" class="control-label">العنوان</label>
                                    <input asp-for="Address" class="form-control" />
                                    <span asp-validation-for="Address" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Contact Information Tab -->
                        <div class="tab-pane fade" id="contact-info" role="tabpanel" aria-labelledby="contact-info-tab">
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="Phone" class="control-label">الهاتف</label>
                                    <input asp-for="Phone" class="form-control" />
                                    <span asp-validation-for="Phone" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="Email" class="control-label">البريد الإلكتروني</label>
                                    <input asp-for="Email" class="form-control" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Employment Information Tab -->
                        <div class="tab-pane fade" id="employment-info" role="tabpanel" aria-labelledby="employment-info-tab">
                            <div class="row">
                                <div class="form-group col-md-4">
                                    <label asp-for="Code" class="control-label">كود الموظف</label>
                                    <input asp-for="Code" class="form-control" readonly="readonly" placeholder="يتم إنشاؤه تلقائياً" />
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="HireDate" class="control-label">تاريخ التعيين <span class="text-danger">*</span></label>
                                    <input asp-for="HireDate" type="date" class="form-control" />
                                    <span asp-validation-for="HireDate" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="TerminationDate" class="control-label">تاريخ انتهاء الخدمة</label>
                                    <input asp-for="TerminationDate" type="date" class="form-control" />
                                    <span asp-validation-for="TerminationDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-4">
                                    <label asp-for="EmploymentTypeId" class="control-label">نوع التوظيف</label>
                                    <select asp-for="EmploymentTypeId" class="form-control" asp-items="ViewBag.EmploymentTypeId"></select>
                                    <span asp-validation-for="EmploymentTypeId" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="JobTitleId" class="control-label">المسمى الوظيفي</label>
                                    <select asp-for="JobTitleId" class="form-control" asp-items="ViewBag.JobTitleId"></select>
                                    <span asp-validation-for="JobTitleId" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label asp-for="JobGradeId" class="control-label">الدرجة الوظيفية</label>
                                    <select asp-for="JobGradeId" class="form-control" asp-items="ViewBag.JobGradeId"></select>
                                    <span asp-validation-for="JobGradeId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="FunctionalGroupId" class="control-label">المجموعة الوظيفية</label>
                                    <select asp-for="FunctionalGroupId" class="form-control" asp-items="ViewBag.FunctionalGroupId"></select>
                                    <span asp-validation-for="FunctionalGroupId" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="OrgUnitId" class="control-label">الوحدة التنظيمية</label>
                                    <select asp-for="OrgUnitId" class="form-control" asp-items="ViewBag.OrgUnitId"></select>
                                    <span asp-validation-for="OrgUnitId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="IsActive" />
                                    <label class="form-check-label" asp-for="IsActive">نشط</label>
                                </div>
                            </div>
                        </div>

                        <!-- Education Information Tab -->
                        <div class="tab-pane fade" id="education-info" role="tabpanel" aria-labelledby="education-info-tab">
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="QualificationTypeId" class="control-label">نوع المؤهل</label>
                                    <select asp-for="QualificationTypeId" class="form-control" asp-items="ViewBag.QualificationTypeId"></select>
                                    <span asp-validation-for="QualificationTypeId" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="Specialization" class="control-label">التخصص</label>
                                    <input asp-for="Specialization" class="form-control" />
                                    <span asp-validation-for="Specialization" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">حفظ</button>
                    <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Optional: Add any client-side script if needed, for example, for cascading dropdowns.
    </script>
}
